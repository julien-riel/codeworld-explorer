{
  "name": "codeworld-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run --passWithNoTests",
    "build": "pnpm -r build",
    "corpus:build": "pnpm --filter @codeworld/analyzer build && node tools/corpus/build.mjs",
    "corpus:check": "pnpm --filter @codeworld/analyzer build && node tools/corpus/check.mjs",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
